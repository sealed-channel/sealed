{
  "name": "sealed-indexer",
  "version": "0.2.0",
  "private": true,
  "description": "Sealed indexer service. Reached via OHTTP gateway; outbound push goes via OHTTP. No Tor, no WebSocket.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "build:all": "npm run build && npm run build:scripts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@algorandfoundation/algokit-subscriber": "^3.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "algosdk": "^3.5.2",
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "hpke-js": "^1.8.0",
    "jsonwebtoken": "9.0.3",
    "pino": "^8.17.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
